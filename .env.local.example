NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
RESEND_API_KEY=your-resend-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Required for seed/unseed scripts (local development only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=eventtara
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

CONFLUENCE_BASE_URL=your-confluence-base-url
CONFLUENCE_EMAIL=your-confluence-email
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=your-confluence-space-key
ANTHROPIC_API_KEY=claude-api-key

# Push notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEBHOOK_SECRET=

# Strava integration (OAuth + API)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
NEXT_PUBLIC_STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_WEBHOOK_VERIFY_TOKEN=a-random-string-for-webhook-verification

# Weather forecast (WeatherAPI.com — free tier)
WEATHERAPI_KEY=

# Admin panel (comma-separated Supabase user IDs)
ADMIN_USER_IDS=
ADMIN_DEV_STAGING_USER_IDS=