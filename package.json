{
  "name": "eventtara",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "preinstall": "node scripts/check-pnpm.cjs",
    "dev": "node scripts/check-pnpm.cjs && next dev --turbopack --port ${PORT:-3001}",
    "build": "node scripts/check-pnpm.cjs && next build",
    "start": "node scripts/check-pnpm.cjs && next start",
    "lint": "node scripts/check-pnpm.cjs && eslint --ext .ts,.tsx src/",
    "seed": "pnpm tsx scripts/seed.ts",
    "seed:staging": "pnpm tsx scripts/seed.ts --staging",
    "unseed": "pnpm tsx scripts/unseed.ts",
    "unseed:staging": "pnpm tsx scripts/unseed.ts --staging",
    "seed:cms": "pnpm tsx scripts/seed-cms.ts",
    "seed:cms:staging": "pnpm tsx scripts/seed-cms.ts --staging",
    "seed:mountains": "pnpm tsx scripts/seed-mountains.ts",
    "seed:mountains:staging": "pnpm tsx scripts/seed-mountains.ts --staging",
    "docs:sync": "ts-node --compiler-options {\\\"module\\\":\\\"commonjs\\\",\\\"target\\\":\\\"ES2017\\\"} scripts/sync-docs/index.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@mapbox/polyline": "^1.2.1",
    "@serwist/next": "^9.5.6",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/leaflet": "^1.9.21",
    "aws4fetch": "^1.0.20",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/canvas-confetti": "^1.9.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "serwist": "^9.5.6",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
